{
  "name": "vikunja-mcp",
  "version": "0.1.0",
  "description": "Minimal, self-owned MCP server for Vikunja — one dependency, scoped read+additive tools.",
  "type": "module",
  "bin": {
    "vikunja-mcp": "index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node index.js",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage",
    "test:e2e": "node --env-file=.env --test test/e2e.test.js",
    "up": "docker compose up -d",
    "down": "docker compose down",
    "reset": "docker compose down -v",
    "bootstrap": "node scripts/bootstrap.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0"
  },
  "license": "MIT"
}
