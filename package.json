{
  "name": "@eargollo/vikunja-mcp",
  "version": "1.0.1",
  "description": "Minimal, self-owned MCP server for Vikunja — one dependency, scoped read+additive tools.",
  "type": "module",
  "bin": {
    "vikunja-mcp": "index.js"
  },
  "files": [
    "index.js",
    "api.js",
    "lib.js",
    "tools.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eargollo/vikunja-mcp.git"
  },
  "homepage": "https://github.com/eargollo/vikunja-mcp#readme",
  "bugs": {
    "url": "https://github.com/eargollo/vikunja-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "vikunja",
    "task-management",
    "todo"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node index.js",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-exclude='test/**' --test-coverage-lines=88 --test-coverage-branches=80 --test-coverage-functions=85",
    "test:e2e": "node --env-file=.env --test test/e2e.test.js",
    "up": "docker compose up -d",
    "down": "docker compose down",
    "reset": "docker compose down -v",
    "bootstrap": "node scripts/bootstrap.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0"
  },
  "license": "MIT"
}
